sName=\"flex items-center gap-2\">\n          <FileText size={22} style={{ color: \"var(--primary)\" }} />\n          <h1 style={{ fontSize: \"var(--font-size-title)\", fontWeight: \"var(--font-weight-bold)\", color: \"var(--foreground)\" }}>\n            每日小结\n          </h1>\n        </div>\n        <div className=\"flex items-center gap-2\">\n          <button\n            onClick={handleRefresh}\n            className=\"p-2 rounded-md\"\n            style={{\n              backgroundColor: \"var(--secondary)\",\n              color: \"var(--secondary-foreground)\",\n              minWidth: \"44px\",\n              minHeight: \"44px\",\n              display: \"flex\",\n              alignItems: \"center\",\n              justifyContent: \"center\",\n            }}\n          >\n            <RefreshCw size={18} />\n          </button>\n          <button\n            onClick={handleCopy}\n            className=\"p-2 rounded-md\"\n            style={{\n              backgroundColor: copied ? \"var(--success)\" : \"var(--primary)\",\n              color: \"var(--primary-foreground)\",\n              minWidth: \"44px\",\n              minHeight: \"44px\",\n              display: \"flex\",\n              alignItems: \"center\",\n              justifyContent: \"center\",\n            }}\n          >\n            {copied ? <Check size={18} /> : <Copy size={18} />}\n          </button>\n        </div>\n      </header>\n\n      <main className=\"flex-1 px-4 py-3\">\n        <FadeIn>\n          <div\n            className=\"rounded-lg p-4\"\n            style={{\n              backgroundColor: \"var(--card)\",\n              border: \"1px solid var(--border)\",\n            }}\n          >\n            <div\n              className=\"font-mono whitespace-pre-wrap leading-relaxed\"\n              style={{ fontSize: \"var(--font-size-label)\", color: \"var(--foreground)\" }}\n            >\n              {entries.length === 0 ? (\n                <div className=\"text-center py-8\" style={{ color: \"var(--muted-foreground)\" }}>\n                  <p>今日暂无动态</p>\n                  <p style={{ fontSize: \"var(--font-size-small)\", marginTop: \"var(--spacing-xs)\" }}>\n                    完成待办、录入查血或确认换药后会自动生成小结\n                  </p>\n                </div>\n              ) : (\n                <div>\n                  <div style={{ fontWeight: \"var(--font-weight-bold)\", marginBottom: \"var(--spacing-sm)\" }}>\n                    📅 {today} 工作小结\n                  </div>\n                  <div className=\"space-y-3\">\n                    {entries.map((entry, idx) => (\n                      <motion.div\n                        key={entry.bedNumber}\n                        initial={{ opacity: 0, x: -8 }}\n                        animate={{ opacity: 1, x: 0 }}\n                        transition={{ delay: idx * 0.05 }}\n                      >\n                        <div style={{ fontWeight: \"var(--font-weight-semibold)\" }}>\n                          👤 {entry.bedNumber} {entry.name}\n                        </div>\n                        {entry.completedTodos.map((todo, ti) => (\n                          <div key={ti} style={{ paddingLeft: \"var(--spacing-lg)\", color: \"var(--success)\" }}>\n                            ✅ {todo}\n                          </div>\n                        ))}\n                        {entry.bloodChecked && (\n                          <div style={{ paddingLeft: \"var(--spacing-lg)\", color: \"var(--info)\" }}>\n                            💉 今日已查血\n                          </div>\n                        )}\n                        {entry.dressingChanged && (\n                          <div style={{ paddingLeft: \"var(--spacing-lg)\", color: \"var(--info)\" }}>\n                            🩹 已换药\n                          </div>\n                        )}\n                      </motion.div>\n                    ))}\n                  </div>\n                </div>\n              )}\n            </div>\n          </div>\n        </FadeIn>\n      </main>\n    </div>\n  );\n}\n","file_path":"/workspace/frontend/src/pages/DailySummaryPage.tsx"},"tool_response":"Successfully created and wrote to new file: /workspace/frontend/src/pages/DailySummaryPage.tsx","call_id":"call_00_weNzjl8UAInHnBKh27Lc6042","tool_use_id":"call_00_weNzjl8UAInHnBKh27Lc6042","agent_type":"cli","permission_mode":"dontAsk","client":"CLI","version":"2.99.0","generation_id":"6d1ed7170eb348c5aaed3638d5d0dff3","model":"auto"}
