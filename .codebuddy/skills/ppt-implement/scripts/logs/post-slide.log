nt={<PageTransition transition=\"slide-up\"><PatientDetail /></PageTransition>}\n            />\n            <Route\n              path=\"/todos\"\n              data-genie-title=\"Todo Summary\"\n              data-genie-key=\"TodoSummary\"\n              element={<PageTransition transition=\"slide-up\"><TodoSummary /></PageTransition>}\n            />\n            <Route\n              path=\"/summary\"\n              data-genie-title=\"Daily Summary\"\n              data-genie-key=\"DailySummary\"\n              element={<PageTransition transition=\"slide-up\"><DailySummaryPage /></PageTransition>}\n            />\n            <Route\n              path=\"/data\"\n              data-genie-title=\"Data Management\"\n              data-genie-key=\"DataManagement\"\n              element={<PageTransition transition=\"slide-up\"><DataManagement /></PageTransition>}\n            />\n          </AnimatedRoutes>\n        </div>\n        <BottomNav />\n      </div>\n    </BrowserRouter>\n  );\n}\n\nfunction App() {\n  return (\n    <TooltipProvider>\n      <Toaster position=\"top-center\" />\n      <AppContent />\n    </TooltipProvider>\n  );\n}\n\nexport default App;\n","file_path":"/workspace/frontend/src/App.tsx"},"tool_response":"Successfully overwrote file: /workspace/frontend/src/App.tsx","call_id":"call_00_TzhuSp6ErGRcalA48MTw5353","tool_use_id":"call_00_TzhuSp6ErGRcalA48MTw5353","agent_type":"cli","permission_mode":"dontAsk","client":"CLI","version":"2.99.0","generation_id":"68263ce5a050490dbd706db6dd7e8c63","model":"auto"}
