rors, setErrors] = useState<{ bedNumber?: string; name?: string }>({});\n  const bedInputRef = useRef<HTMLInputElement>(null);\n\n  useEffect(() => {\n    if (open) {\n      setTimeout(() => bedInputRef.current?.focus(), 100);\n      setErrors({});\n    }\n  }, [open]);\n\n  const handleSubmit = async () => {\n    const newErrors: { bedNumber?: string; name?: string } = {};\n    if (!bedNumber.trim()) newErrors.bedNumber = \"请输入床号\";\n    if (!name.trim()) newErrors.name = \"请输入姓名\";\n    if (Object.keys(newErrors).length > 0) {\n      setErrors(newErrors);\n      return;\n    }\n    await onAdd({ bedNumber: bedNumber.trim(), name: name.trim(), group });\n    setBedNumber(\"\");\n    setName(\"\");\n    setGroup(\"解组\");\n    setErrors({});\n    onOpenChange(false);\n  };\n  \n  const handleClose = () => {\n    setErrors({});\n    onOpenChange(false);\n  };"},"tool_response":"Successfully edited file: /workspace/frontend/src/components/AddPatientDialog.tsx","call_id":"call_00_Db0ozmZHzVYnszITFVst0902","tool_use_id":"call_00_Db0ozmZHzVYnszITFVst0902","agent_type":"cli","permission_mode":"dontAsk","client":"CLI","version":"2.99.0","generation_id":"5ac57702dfbf4130a7feb53f728c9b06","model":"deepseek-v4-pro"}
